# Catalyst Configuration
CATALYST_PROJECT_ID=47976000000030001
ENVIRONMENT=development
PORT=8000

# OAuth 2.0 - Zoho Profile/Region Selection
ZOHO_PROFILE=in
# Options: in (India), us (USA), eu (Europe)

# OAuth 2.0 Credentials - India Region (zoho.in)
ZOHO_CLIENT_ID_IN=your_client_id_in_here
ZOHO_CLIENT_SECRET_IN=your_client_secret_in_here

# OAuth 2.0 Credentials - US Region (zoho.com)
# Uncomment if using US data center
# ZOHO_CLIENT_ID_US=your_client_id_us_here
# ZOHO_CLIENT_SECRET_US=your_client_secret_us_here

# OAuth 2.0 Credentials - EU Region (zoho.eu)
# Uncomment if using EU data center
# ZOHO_CLIENT_ID_EU=your_client_id_eu_here
# ZOHO_CLIENT_SECRET_EU=your_client_secret_eu_here

# Token Configuration
TOKEN_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30
TOKEN_ENCRYPTION_KEY=change-this-in-production
